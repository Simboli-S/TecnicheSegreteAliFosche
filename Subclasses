	"subclassFeature": [
		{
			"name": "Lesser Natural Control",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Storm",
			"subclassSource": "AliFosche",
			"level": 3,
			"entries": [
				"You learn the {@spell elementalism|xphb} cantrip. Constitution is your spellcasting modifier for it."
			]
		},
		{
			"name": "Storm Aura",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Storm",
			"subclassSource": "AliFosche",
			"level": 3,
			"entries": [
				"Whenever you activate your Rage, choose Desert, Sea, or Tundra. You extend an aura in a 10-foot Emanation originating from yourself for the duration of your Rage. Your aura has an effect that activates when you enter your Rage and again at the start of each of your turns. The effect depends on the chosen environment, as detailed below. If your Aura requires a saving throw, the DC equals 8 plus your Constitution modifier and your proficiency bonus.",
				{
					"type": "list",
					"items": [
						{
							"type": "item",
							"name": "Desert",
							"entries": [
								"Roll a number of d6s equal to your Rage damage bonus and add them together. Each creature of your choice in the aura must succeed on a Dexterity saving throw or take fire damage equal to the number rolled."
							]
						},
						{
							"type": "item",
							"name": "Sea",
							"entries": [
								"Roll a number of d8s equal to your Rage damage bonus and add them together. One creature of your choice within your aura must make a Dexterity saving throw, taking lightning damage equal to the number rolled on a failed save or half as much on a successful one."
							]
						},
						{
							"type": "item",
							"name": "Tundra",
							"entries": [
								"Roll a number of d6s equal to your Rage damage bonus and add them together. One creature of your choice within your aura must succeed on a Strength saving throw or it subtracts the number rolled from the next damage roll it makes before the start of your next turn."
							]
						}
					]
				}
			]
		},
		{
			"name": "Storm Soul",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Storm",
			"subclassSource": "AliFosche",
			"level": 6,
			"entries": [
				"When you finish a Long or Short rest, choose one of the following benefits that lasts until you use this feature again.",
				{
					"type": "list",
					"items": [
						{
							"type": "item",
							"name": "Desert",
							"entries": [
								"You gain Resistance to Fire damage, and as a Magic action you can touch a flammable object that isn't being worn or carried and cause it to start burning."
							]
						},
						{
							"type": "item",
							"name": "Sea",
							"entries": [
								"You gain Resistance to Lightning damage, can breathe underwater, and gain a Swim Speed equal to your Speed."
							]
						},
						{
							"type": "item",
							"name": "Tundra",
							"entries": [
								"You gain Resistance to Cold damage. As a Magic action you can touch water to turn an unoccupied 5-foot Cube of it into ice, which melts after 1 minute."
							]
						}
					]
				}
			]
		},
		{
			"name": "Raging Storm",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Storm",
			"subclassSource": "AliFosche",
			"level": 10,
			"entries": [
				"The power of the storm you channel grows mightier, lashing out at your foes. The effect is based on the environment you choose for your Storm Aura.",
				{
					"type": "list",
					"items": [
						{
							"type": "item",
							"name": "Desert",
							"entries": [
								"When a creature fails its saving throw against your Storm Aura effect, it is engulfed with flames. For 1 minute the target takes {@damage 2d6} fire damage at the start of each of its turns, unless it uses an action to stop the flames."
							]
						},
						{
							"type": "item",
							"name": "Sea",
							"entries": [
								"When you deal your Storm Aura effect damage, you can choose another creature within 30 feet of the original target. The new target makes the same Dexterity saving throw as the original."
							]
						},
						{
							"type": "item",
							"name": "Tundra",
							"entries": [
								"When a creature fails the saving throw against your Storm Aura effect, it takes {@damage 2d6} cold damage and its speed becomes 0 until the end of its next turn."
							]
						}
					]
				}
			]
		},
		{
			"name": "Shielding Aura",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Storm",
			"subclassSource": "AliFosche",
			"level": 14,
			"entries": [
				"You gain immunity instead of resistance to the damage type of your Storm Soul feature. Moreover, each creature of your choice within a 15-foot Emanation from you gains the benefits of your Storm Soul feature."
			]
		},
		{
			"name": "Giant's Power",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Giant",
			"subclassSource": "AliFosche",
			"level": 3,
			"entries": [
				"You know {@language Giant} or another language of your choice, if you already know it. You learn the {@spell druidcraft|xphb} or {@spell thaumaturgy|xphb} cantrip and Strength is your spellcasting ability for it."
			]
		},
		{
			"name": "Giant's Havoc",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Giant",
			"subclassSource": "AliFosche",
			"level": 3,
			"entries": [
				"Your rage channels the primal might of giants. While raging, you gain the following benefits:",
				{
					"type": "list",
					"items": [
						{
							"type": "item",
							"name": "Improved Reach",
							"entries": [
								"The reach of your attacks is increased by 5 feet."
							]
						},
						{
							"type": "item",
							"name": "Mighty Stature",
							"entries": [
								"If you are smaller than Large, you become Large along with anything you are wearing. If you lack the room to become Large, your size doesn't change."
							]
						}
					]
				}
			]
		},
		{
			"name": "Elemental Cleaver",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Giant",
			"subclassSource": "AliFosche",
			"level": 6,
			"entries": [
				"You bond with the elemental might of giants to infuse weapons with primordial energy. When you enter your rage, you can give the following benefits to a weapon you're holding.",
				{
					"type": "list",
					"items": [
						{
							"type": "item",
							"name": "Primal Power",
							"entries": [
								"Choose one of the following damage types: Cold, Fire, Lightning or Thunder. Once every turn, the weapon deals {@damage 1d12} extra damage of the chosen type."
							]
						},
						{
							"type": "item",
							"name": "Returning",
							"entries": [
								"The weapon gains the thrown property (20/60). If you throw the weapon, it reappears in your hand the instant after it hits or misses a target."
							]
						}
					]
				},
				"The infused weapon's benefits are suppressed while a creature other than you wields it."
			]
		},
		{
			"name": "Mighty Impel",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Giant",
			"subclassSource": "AliFosche",
			"level": 10,
			"entries": [
				"Your strength allows you to hurl creatures on the battlefield. While raging, you can use a Bonus Action to force a Large or smaller creature within your reach to make a Strength saving throw (DC equals 8 plus your Strength modifier and proficiency bonus). On a failed save, the creature is moved to an unoccupied space you can see within 30 feet of you."
			]
		},
		{
			"name": "Demiurgic Colossus",
			"source": "AliFosche",
			"className": "Barbarian",
			"classSource": "XPHB",
			"subclassShortName": "Giant",
			"subclassSource": "AliFosche",
			"level": 14,
			"entries": [
				"The primordial power of your rage intensifies. When you rage, your reach increases by 10 feet, your size can increase to Large or Huge (your choice) and the extra damage dealt by your Elemental Cleaver feature increases to {@damage 2d12}."
			]
		},
		{
			"name": "Psychic Blades",
			"source": "AliFosche",
			"className": "Bard",
			"classSource": "XPHB",
			"subclassShortName": "Whispers",
			"subclassSource": "AliFosche",
			"level": 3,
			"entries": [
				"Your mastery of psychic magic gives you the following benefits.",
				"You learn the {@spell shadow blade|xge} spell and it counts as a Bard spell for you.",
				"When you hit with a weapon attack or deal Psychic damage you can expend one use of your Bardic Inspiration to deal extra Psychic damage equal to three rolls of your Bardic Inspiration die."
			]
		},
		{
			"name": "Words of Terror",
			"source": "AliFosche",
			"className": "Bard",
			"classSource": "XPHB",
			"subclassShortName": "Whispers",
			"subclassSource": "AliFosche",
			"level": 3,
			"entries": [
				"If you speak for 1 minute to a creature with an Intelligence ability score of at least 6, you can attempt to seed paranoia in its mind. At the end of the conversation, the target must succeed on a Wisdom saving throw against your spell save DC or be {@condition Frightened} by you. The target is frightened in this way for 1 hour, until it or one of its allies are harmed. If the target succeeds on its saving throw, the target has no hint that you tried to frighten it. Once you use this feature, you can't use it again until you finish a Short or Long rest."
			]
		},
		{
			"name": "Mantle of Whispers",
			"source": "AliFosche",
			"className": "Bard",
			"classSource": "XPHB",
			"subclassShortName": "Whispers",
			"subclassSource": "AliFosche",
			"level": 6,
			"entries": [
				"When a Medium or Small creature within 30 feet of you reaches 0 hit points, you steal its shadow. You can take a Bonus Action to spend the shadow and gain the following benefits.",
				{
					"type": "list",
					"items": [
						{
							"type": "item",
							"name": "Dark Resilience",
							"entries": [
								"You gain temporary hit points equal to your Bard level."
							]
						},
						{
							"type": "item",
							"name": "Psychic Whispers",
							"entries": [
								"For 1 hour, you take the creature's appearance and learn general details on the creature's background and personal life."
							]
						}
					]
				},
				"You can use this feature a number of times equal to your Charisma modifier (minimum of once) and regain all expended uses when you finish a Long rest."
			]
		},
		{
			"name": "Mischievous Afterimage",
			"source": "AliFosche",
			"className": "Bard",
			"classSource": "XPHB",
			"subclassShortName": "Whispers",
			"subclassSource": "AliFosche",
			"level": 6,
			"entries": [
				"Immediately you deal damage with your Psychic Blades feature, you can teleport 15 feet in an unoccupied space you can see."
			]
		},
		{
			"name": "Shadow Lore",
			"source": "AliFosche",
			"className": "Bard",
			"classSource": "XPHB",
			"subclassShortName": "Whispers",
			"subclassSource": "AliFosche",
			"level": 14,
			"entries": [
				"As a Magic Action, you whisper in the mind of a creature within 30 feet of you. It must make a Wisdom saving throw against your spell DC. On a failed save, your whispers sound like the target's most dark secrets and fears. It is {@condition Charmed} by you and obeys your commands for 8 hours or until you or your allies harm it. The target won't risk its life for you, but can grant you favors and gifts. When the effect ends, it has no understanding of this fear. On a successful save, your whisper sounds like unintelligible mumbling and has no effect. Once you use this feature, you can't use it again until you finish a Long rest."
			]
		},
		{
			"name": "Arcane Lore",
			"source": "AliFosche",
			"className": "Fighter",
			"classSource": "XPHB",
			"subclassShortName": "Arcane Archer",
			"subclassSource": "AliFosche",
			"level": 3,
			"entries": [
				"You studied magical theory and secrets of nature, granting you the following benefits. You know either the {@spell druidcraft|xphb} or {@spell prestidigitation|xphb} cantrip. Intelligence is your spellcasting ability for it. In addition, you gain proficiency in the {@skill Arcana} and {@skill Nature} skills. If you already have one of these proficiencies, you gain proficiency in a different skill of your choice."
			]
		},
		{
			"name": "Arcane Shot",
			"source": "AliFosche",
			"className": "Fighter",
			"classSource": "XPHB",
			"subclassShortName": "Arcane Archer",
			"subclassSource": "AliFosche",
			"level": 3,
			"entries": [
				"You learn to unleash special magical effects with your shots.",
				"{@b Arcane Shot Options.} You learn two Arcane Shot options of your choice from the \"Arcane Shot Options\" of this subclass. You learn an additional Arcane Shot option of your choice when you reach Fighter levels 7, 10 and 15.",
				"{@b Using Arcane Shot.} Once per turn when you make a ranged attack using a weapon with the ammunition property, you can apply one Arcane Shot option to that attack. You decide to use the option when you hit a creature and deal damage to it. You can use this feature a number of times equal to your Intelligence modifier (minimum of once). You regain all expended uses when you finish a Short or Long rest.",
				"{@b Arcane Shot Die.} The dice used by your Arcane Shot Options is a d6. The Arcane Shot Die becomes a d8 at level 10, a d10 at level 15 and a d12 at level 18.",
				"{@b Saving Throws.} If an Arcane Shot option requires a saving throw, the DC equals 8 plus your Intelligence modifier and Proficiency Bonus."
			]
		},
		{
			"name": "Arcane Shot Options",
			"source": "AliFosche",
			"className": "Fighter",
			"classSource": "XPHB",
			"subclassShortName": "Arcane Archer",
			"subclassSource": "AliFosche",
			"level": 3,
			"entries": [
				"The Arcane Shot options are presented here in alphabetical order.",
				{
					"type": "list",
					"items": [
						{
							"type": "item",
							"name": "Banishing Shot",
							"entries": [
								"The target of the attack takes Psychic damage equal to one roll of your Arcane Shot die and must succeed on a Charisma saving throw or be banished until the end of its next turn. While banished, the target has the {@condition incapacitated} condition and its speed is 0."
							]
						},
						{
							"type": "item",
							"name": "Bursting Shot",
							"entries": [
								"The target of the attack and each creature within a 10-foot emanation originating from it takes Force damage equal to two rolls of your Arcane shot die."
							]
						},
						{
							"type": "item",
							"name": "Enfeebling Shot",
							"entries": [
								"The target of the attack takes Necrotic damage equal to two rolls of your Arcane shot die and must succeed on a Strength saving throw. On a failed save, each damage roll of the target is reduced by an amount equal to one roll of your Arcane Shot Die."
							]
						},
						{
							"type": "item",
							"name": "Grasping Shot",
							"entries": [
								"The target of the attack takes Slashing damage equal to one roll of your Arcane Shot Die and must succeed on a Dexterity saving throw or have the {@condition restrained} condition for 1 minute. The target can take an action to remove the brambles ending the restrained condition."
							]
						},
						{
							"type": "item",
							"name": "Piercing Shot",
							"entries": [
								"You don't make an attack roll for the attack. Each creature in a 30-foot long and 5-foot wide line originating from you must make a Dexterity saving throw. On a failed save, a creature takes Piercing damage equal to four rolls of your Arcane Shot Die, half as much damage on a successful one."
							]
						}
					]
				}
			]
		},
		{
			"name": "Curving Shot",
			"source": "AliFosche",
			"className": "Fighter",
			"classSource": "XPHB",
			"subclassShortName": "Arcane Archer",
			"subclassSource": "AliFosche",
			"level": 7,
			"entries": [
				"You learn how to direct an errant arrow toward a new target. If you make an attack roll with a weapon with the ammunition property and miss, you can cause the shot to ricochet as a Bonus Action. Make a new attack roll against another creature you can see within 60 feet of the original target."
			]
		},
		{
			"name": "Magical Ammunition",
			"source": "AliFosche",
			"className": "Fighter",
			"classSource": "XPHB",
			"subclassShortName": "Arcane Archer",
			"subclassSource": "AliFosche",
			"level": 7,
			"entries": [
				"When you shoot an ammunition, you can imbue it with one of the following properties.",
				{
					"type": "list",
					"items": [
						{
							"type": "item",
							"name": "Darkening Shot",
							"entries": [
								"Magical darkness fills a 15-foot emanation originating from the ammunition for 1 minute."
							]
						},
						{
							"type": "item",
							"name": "Unlocking Shot",
							"entries": [
								"A burst of magic fills a 15-foot emanation originating from the ammunition. Any mundane lock in the emanation becomes unlocked."
							]
						},
						{
							"type": "item",
							"name": "Vine Shot",
							"entries": [
								"A 60-foot long vine grows from the ammunition. You and other creatures can then climb it. The vine withers away after 10 minutes."
							]
						}
