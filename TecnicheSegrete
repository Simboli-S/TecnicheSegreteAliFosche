        },
        {
            "name": "Truth Serum (TAF)",
            "source": "AliFosche",
            "type": "G",
            "rarity": "common",
            "entries": [
                "{@i Ingested:} A creature hit by this poison must succeed on a DC 12 Constitution saving throw or become {@condition poisoned} for 1 hour. The {@condition poisoned} creature can't knowingly speak a deliberate lie."
            ]
        },
        {
            "name": "Ethereal Agony (TAF)",
            "source": "AliFosche",
            "type": "G",
            "rarity": "uncommon",
            "entries": [
                "{@i Inhaled:} A creature hit by this poison and each creature within 5 feet of it takes {@damage 2d6} poison damage and is {@condition poisoned} for 1 minute. At the start of each of the {@condition poisoned} creature's turns, it takes {@damage 1d6} poison damage."
            ]
        },
        {
            "name": "Grung Touch (TAF)",
            "source": "AliFosche",
            "type": "G",
            "rarity": "uncommon",
            "entries": [
                "{@i Injury:} For 1 minute, a creature subjected to this poison must roll {@dice 1d4} at the start of its turn to determine the effect it suffers. At the end of its turn, the target can make a Constitution save (DC 13) to end the effect.",
